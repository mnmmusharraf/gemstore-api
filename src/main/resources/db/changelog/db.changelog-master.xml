<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.26.xsd">

    <!-- 1. Create the initial table, comments, and indexes -->
    <changeSet id="20251114162740-1" author="mnm-musharraf">
        <sqlFile path="V1__init.sql" relativeToChangelogFile="true"/>
    </changeSet>

    <!-- 2. Create the function. The special attributes are now on the <sqlFile> tag. -->
    <changeSet id="20251114162740-2" author="mnm-musharraf">
        <sqlFile path="V2__set_users_updated_at.sql"
                 relativeToChangelogFile="true"
                 splitStatements="false"
                 endDelimiter="$func$"/>
    </changeSet>

    <!-- 3. Create the trigger that uses the function -->
    <changeSet id="20251114162740-3" author="mnm-musharraf">
        <sqlFile path="V3__trg_users_updated_at.sql" relativeToChangelogFile="true"/>
    </changeSet>

</databaseChangeLog>